# ── Required ────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Docker: use postgres as hostname)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://wbos:changeme@postgres:5432/wbos?schema=public"

# Better Auth secret (generate with: openssl rand -hex 32)
BETTER_AUTH_SECRET="change-me-to-a-random-secret"

# ── Optional ────────────────────────────────────────────────────────────────

# Application URL (used for origin validation, cookie domain, and callback URLs)
# Must match the public URL users access in the browser.
# If behind a reverse proxy, set to the public HTTPS URL (e.g. https://wbos.example.com)
BETTER_AUTH_URL="http://localhost:3000"

# Additional trusted origins for Better Auth (comma-separated)
# Useful in development or when behind a reverse proxy.
# Example: BETTER_AUTH_TRUSTED_ORIGINS="http://localhost:3000,http://192.168.100.36:3000"
BETTER_AUTH_TRUSTED_ORIGINS="http://localhost:3000"

# Internal URL for server-side rendering (Playwright PDF generation uses this)
# In Docker, set to http://127.0.0.1:3000 so Playwright can reach the app
INTERNAL_APP_URL="http://127.0.0.1:3000"

# PostgreSQL password (used by docker-compose to set up the database)
POSTGRES_PASSWORD="changeme"

# Host port to bind the application to (default: 3000)
PORT=3000

# Storage root for uploaded files (default: ./storage)
WBOS_STORAGE_ROOT="./storage"

# ── Backup (optional overrides) ─────────────────────────────────────────────

# WBOS_BACKUP_DIR="./backups"
# WBOS_BACKUP_RETENTION_DAYS=30
