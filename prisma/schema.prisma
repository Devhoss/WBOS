generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationRole {
  OWNER
  ADMIN
  MANAGER
  SALES
  WAREHOUSE
  FINANCE
  VIEWER
}

enum CurrencyCode {
  KWD
  USD
  EUR
}

enum DocumentType {
  INV
  PO
  CN
  PAY
  GRN
}

enum StorageProvider {
  LOCAL
}

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions      Session[]
  accounts      Account[]
  memberships   OrganizationMembership[]
  activityLogs  ActivityLog[]
  attachments   Attachment[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

model Organization {
  id              String   @id @default(cuid())
  name            String
  legalName       String?
  defaultCurrency CurrencyCode @default(KWD)
  timezone        String   @default("Asia/Kuwait")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  archivedAt      DateTime?

  memberships       OrganizationMembership[]
  settings          BusinessSettings?
  activityLogs      ActivityLog[]
  attachments       Attachment[]
  documentSequences DocumentSequence[]

  @@map("organizations")
}

model OrganizationMembership {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  role           OrganizationRole @default(OWNER)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_memberships")
}

model BusinessSettings {
  id              String       @id @default(cuid())
  organizationId  String       @unique
  businessName    String
  defaultCurrency CurrencyCode @default(KWD)
  timezone        String       @default("Asia/Kuwait")
  invoicePrefix   String       @default("INV")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("business_settings")
}

model ActivityLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  action         String
  entityType     String
  entityId       String?
  summary        String
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([entityType, entityId])
  @@map("activity_logs")
}

model Attachment {
  id             String          @id @default(cuid())
  organizationId String
  uploadedById   String?
  entityType     String
  entityId       String
  fileName       String
  mimeType       String
  sizeBytes      Int
  provider       StorageProvider @default(LOCAL)
  storageKey     String
  createdAt      DateTime        @default(now())
  archivedAt     DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  uploadedBy   User?        @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([organizationId, entityType, entityId])
  @@map("attachments")
}

model DocumentSequence {
  id              String       @id @default(cuid())
  organizationId  String
  documentType    DocumentType
  year            Int
  currentSequence Int          @default(0)
  prefix          String
  separator       String       @default("-")
  digits          Int          @default(6)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, documentType, year])
  @@map("document_sequences")
}
