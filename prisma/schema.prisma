generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationRole {
  OWNER
  ADMIN
  MANAGER
  SALES
  WAREHOUSE
  FINANCE
  VIEWER
}

enum CurrencyCode {
  KWD
  USD
  EUR
}

enum DocumentType {
  INV
  PO
  CN
  PAY
  GRN
}

enum StorageProvider {
  LOCAL
}

enum ProductStatus {
  DRAFT
  ACTIVE
  DISCONTINUED
  ARCHIVED
}

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions      Session[]
  accounts      Account[]
  memberships   OrganizationMembership[]
  activityLogs  ActivityLog[]
  attachments   Attachment[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

model Organization {
  id              String   @id @default(cuid())
  name            String
  legalName       String?
  defaultCurrency CurrencyCode @default(KWD)
  timezone        String   @default("Asia/Kuwait")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  archivedAt      DateTime?

  memberships       OrganizationMembership[]
  settings          BusinessSettings?
  activityLogs      ActivityLog[]
  attachments       Attachment[]
  documentSequences DocumentSequence[]
  warehouses        Warehouse[]
  categories        Category[]
  suppliers         Supplier[]
  customers         Customer[]
  unitsOfMeasure    UnitOfMeasure[]
  products          Product[]

  @@map("organizations")
}

model Product {
  id                  String        @id @default(cuid())
  organizationId      String
  categoryId          String
  supplierId          String?
  unitOfMeasureId     String
  sku                 String
  barcode             String?
  name                String
  description         String?
  status              ProductStatus @default(DRAFT)
  defaultSellingPrice Decimal?      @db.Decimal(18, 3)
  defaultCurrency     CurrencyCode  @default(KWD)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  archivedAt          DateTime?

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category      Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  supplier      Supplier?     @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  unitOfMeasure UnitOfMeasure @relation(fields: [unitOfMeasureId], references: [id], onDelete: Restrict)

  @@unique([organizationId, sku])
  @@unique([organizationId, barcode])
  @@index([organizationId, sku])
  @@index([organizationId, barcode])
  @@index([organizationId, name])
  @@index([organizationId, status])
  @@index([organizationId, archivedAt])
  @@index([categoryId])
  @@index([supplierId])
  @@map("products")
}

model UnitOfMeasure {
  id                 String   @id @default(cuid())
  organizationId     String
  name               String
  code               String
  description        String?
  isBaseUnit         Boolean  @default(false)
  conversionToBase   Decimal  @default(1) @db.Decimal(18, 6)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  archivedAt         DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products     Product[]

  @@unique([organizationId, name])
  @@unique([organizationId, code])
  @@index([organizationId, archivedAt])
  @@map("units_of_measure")
}

model Customer {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  code           String?
  contactName    String?
  email          String?
  phone          String?
  address        String?
  paymentTerms   String?
  creditLimit    Decimal? @db.Decimal(18, 3)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  archivedAt     DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@unique([organizationId, code])
  @@index([organizationId, archivedAt])
  @@map("customers")
}

model Supplier {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  code           String?
  contactName    String?
  email          String?
  phone          String?
  address        String?
  paymentTerms   String?
  leadTimeDays   Int?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  archivedAt     DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products     Product[]

  @@unique([organizationId, name])
  @@unique([organizationId, code])
  @@index([organizationId, archivedAt])
  @@map("suppliers")
}

model Category {
  id             String    @id @default(cuid())
  organizationId String
  parentId       String?
  name           String
  code           String?
  description    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  archivedAt     DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent       Category?    @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children     Category[]   @relation("CategoryHierarchy")
  products     Product[]

  @@unique([organizationId, name])
  @@unique([organizationId, code])
  @@index([organizationId, archivedAt])
  @@index([parentId])
  @@map("categories")
}

model Warehouse {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  code           String
  address        String?
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  archivedAt     DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, code])
  @@index([organizationId, archivedAt])
  @@map("warehouses")
}

model OrganizationMembership {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  role           OrganizationRole @default(OWNER)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_memberships")
}

model BusinessSettings {
  id              String       @id @default(cuid())
  organizationId  String       @unique
  businessName    String
  defaultCurrency CurrencyCode @default(KWD)
  timezone        String       @default("Asia/Kuwait")
  invoicePrefix   String       @default("INV")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("business_settings")
}

model ActivityLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  action         String
  entityType     String
  entityId       String?
  summary        String
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([entityType, entityId])
  @@map("activity_logs")
}

model Attachment {
  id             String          @id @default(cuid())
  organizationId String
  uploadedById   String?
  entityType     String
  entityId       String
  fileName       String
  mimeType       String
  sizeBytes      Int
  provider       StorageProvider @default(LOCAL)
  storageKey     String
  createdAt      DateTime        @default(now())
  archivedAt     DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  uploadedBy   User?        @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([organizationId, entityType, entityId])
  @@map("attachments")
}

model DocumentSequence {
  id              String       @id @default(cuid())
  organizationId  String
  documentType    DocumentType
  year            Int
  currentSequence Int          @default(0)
  prefix          String
  separator       String       @default("-")
  digits          Int          @default(6)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, documentType, year])
  @@map("document_sequences")
}
